{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/apps/main/*": ["src/*"],
      "@/apps/design/*": ["../design/src/*"],
      "@/apps/connection/*": ["../connection/src/*"],
      "@/apps/daemon/*": ["../daemon/src/*"],
      "@/apps/shared/*": ["../shared/src/*"],
      "@/apps/monitor/*": ["../monitor/src/*"],
      "@/apps/setting/*": ["../setting/src/*"],
      "@/apps/chat/*": ["../chat/src/*"],
      "@/packages/ui/useOrchestratorDashboard": ["../../packages/ui/src/hooks/useOrchestratorDashboard.ts"],
      "@/packages/ui/*": ["../../packages/ui/src/*"],
      "@/packages/stores": ["../../packages/stores/src/index.ts"],
      "@/packages/stores/*": ["../../packages/stores/src/*"],
      "@/packages/runtime-contracts": ["../../packages/runtime-contracts/src/index.ts"],
      "@/packages/runtime-contracts/*": ["../../packages/runtime-contracts/src/*"],
      "@/packages/agent/*": ["../../packages/agent/src/*"],
      "@/packages/services/pagelet-host/*": ["../../packages/services/src/pagelet-host/src/*"],
      "@/packages/services/main-metrics/*": ["../../packages/services/src/main-metrics/src/*"],
      "@/packages/services/process/*": ["../../packages/services/src/process/src/*"]
    }
  },
  "include": ["src/**/*"]
}
