{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@telegraph/main/*": ["src/*"],
      "@telegraph/pagelet-host/*": ["../../packages/services/src/pagelet-host/src/*"],
      "@telegraph/main-metrics/*": ["../../packages/services/src/main-metrics/src/*"],
      "@telegraph/process/*": ["../../packages/services/src/process/src/*"],
      "@telegraph/connection/*": ["../connection/src/*"],
      "@telegraph/daemon/*": ["../daemon/src/*"],
      "@telegraph/shared/*": ["../shared/src/*"],
      "@telegraph/monitor/*": ["../monitor/src/*"],
      "@telegraph/setting/*": ["../setting/src/*"],
      "@telegraph/design/*": ["../design/src/*"],
      "@telegraph/chat/*": ["../chat/src/*"],
      "@telegraph/ui/*": ["../../packages/ui/src/*"],
      "@telegraph/stores": ["../../packages/stores/src/index.ts"],
      "@telegraph/stores/*": ["../../packages/stores/src/*"],
      "@telegraph/runtime-contracts": ["../../packages/runtime-contracts/src/index.ts"],
      "@telegraph/runtime-contracts/*": ["../../packages/runtime-contracts/src/*"]
    }
  },
  "include": ["src/**/*"]
}
