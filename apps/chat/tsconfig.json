{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@telegraph/chat/*": ["src/*"],
      "@telegraph/pagelet-host/*": ["../../packages/services/src/pagelet-host/src/*"],
      "@telegraph/main-metrics/*": ["../../packages/services/src/main-metrics/src/*"],
      "@telegraph/daemon/*": ["../daemon/src/*"],
      "@telegraph/main/*": ["../main/src/*"],
      "@telegraph/ui/*": ["../../packages/ui/src/*"],
      "@telegraph/stores": ["../../packages/stores/src/index.ts"],
      "@telegraph/stores/*": ["../../packages/stores/src/*"],
      "@telegraph/runtime-contracts": ["../../packages/runtime-contracts/src/index.ts"],
      "@telegraph/runtime-contracts/*": ["../../packages/runtime-contracts/src/*"],
      "@telegraph/agent/*": ["../../packages/agent/src/*"]
    }
  },
  "include": ["src/**/*"]
}
