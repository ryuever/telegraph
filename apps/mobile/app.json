{
  "expo": {
    "name": "Telegraph Mobile",
    "slug": "telegraph-mobile",
    "scheme": "telegraph-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "jsEngine": "hermes",
    "platforms": ["ios", "android"],
    "plugins": ["react-native-bottom-tabs", "./plugins/with-ios-bottom-tabs-build-fixes.cjs"],
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050814"
    },
    "ios": {
      "bundleIdentifier": "app.telegraph.mobile"
    },
    "android": {
      "package": "app.telegraph.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050814"
      }
    }
  }
}
