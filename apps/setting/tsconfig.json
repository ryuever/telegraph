{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/apps/setting/*": ["src/*"],
      "@/packages/services/pagelet-host/*": ["../../packages/services/src/pagelet-host/src/*"],
      "@/packages/services/main-metrics/*": ["../../packages/services/src/main-metrics/src/*"],
      "@/packages/services/log/*": ["../../packages/services/src/log/src/*"],
      "@/apps/shared/*": ["../shared/src/*"],
      "@/apps/daemon/*": ["../daemon/src/*"],
      "@/apps/main/*": ["../main/src/*"],
      "@/packages/agent-protocol": ["../../packages/agent-protocol/src/index.ts"],
      "@/packages/agent-protocol/*": ["../../packages/agent-protocol/src/*"],
      "@/packages/agent-capabilities": ["../../packages/agent-capabilities/src/index.ts"],
      "@/packages/agent-capabilities/*": ["../../packages/agent-capabilities/src/*"],
      "@/packages/agent-extension-host": ["../../packages/agent-extension-host/src/index.ts"],
      "@/packages/agent-extension-host/*": ["../../packages/agent-extension-host/src/*"],
      "@/packages/agent-resources": ["../../packages/agent-resources/src/index.ts"],
      "@/packages/agent-resources/*": ["../../packages/agent-resources/src/*"],
      "@/packages/agent/*": ["../../packages/agent/src/*"],
      "@/packages/run-protocol": ["../../packages/run-protocol/src/index.ts"],
      "@/packages/run-protocol/*": ["../../packages/run-protocol/src/*"],
      "@/packages/remote-protocol": ["../../packages/remote-protocol/src/index.ts"],
      "@/packages/remote-protocol/*": ["../../packages/remote-protocol/src/*"],
      "@/packages/computer-use-protocol": ["../../packages/computer-use-protocol/src/index.ts"],
      "@/packages/computer-use-protocol/*": ["../../packages/computer-use-protocol/src/*"],
      "@/packages/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src/**/*"]
}
