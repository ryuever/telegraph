# Telegraph 模型配置
# 将本文件复制为 .env 并填入你的 API Key
# 支持以下模型提供商：

# ============================================
# MiniMax (中国版 - api.minimaxi.com)
# 支持模型: MiniMax-M2.7, MiniMax-M2.7-highspeed
# ============================================
MINIMAX_CN_API_KEY=sk-cp-J69E7LZrhfF2k-9UWBHMCIk1qsDgA2HuFd6eEEpOIzgcFfEAVg16obe5OPmZfurGJe6e_o1eaWdyuFiLtGWKR-laVaoairdt67_zFML4I6HPq-jRLEWSwX8

# MiniMax 中国版基础 URL (可选，默认: https://api.minimaxi.com)
# MINIMAX_CN_BASE_URL=https://api.minimaxi.com

# ============================================
# MiniMax (国际版 - api.minimax.com)
# 支持模型: MiniMax-M2.7, MiniMax-M2.7-highspeed
# ============================================
# MINIMAX_API_KEY=your_minimax_api_key_here

# MiniMax 国际版基础 URL (可选，默认: https://api.minimax.com)
# MINIMAX_BASE_URL=https://api.minimax.com

# ============================================
# Anthropic (Claude)
# 支持模型: claude-sonnet-4.5
# ============================================
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Anthropic 基础 URL (可选，默认: https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================
# OpenAI (GPT)
# 支持模型: gpt-4o, gpt-4o-mini
# ============================================
# OPENAI_API_KEY=sk-xxxxx

# OpenAI 基础 URL (可选，默认: https://api.openai.com)
# 如果需要使用代理，可以修改此项
# OPENAI_BASE_URL=https://api.openai.com

# ============================================
# OpenAI 兼容模式 (用于第三方兼容 OpenAI 格式的 API)
# 支持模型: MiniMax-Text-01 等自定义模型
# ============================================
# OPENAI_COMPAT_API_KEY=your_api_key_here
# OPENAI_COMPAT_BASE_URL=https://api.minimaxi.com/v1
