{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@telegraph/application/*": ["src/application/*"],
      "@telegraph/core/*": ["src/core/*"],
      "@telegraph/services/*": ["src/services/*"],
      // Phase 4 — design pagelet's renderer surface lives in
      // apps/design/src/application/browser/. Mirror the alias used by
      // vite.renderer.config.ts so `tsc --noEmit` resolves cross-app
      // imports the same way the renderer bundle does at build time.
      "@design/*": ["../design/src/*"],
      // Redirect x-oasis packages to their pre-built dist .d.ts so we get
      // skipLibCheck-style behaviour. Without this, link-to-source pulls
      // their .ts straight in and our `strict: true` flunks the upstream
      // sloppy types (Function, uninitialised fields, etc). Phase 2.5+
      // when we actually edit x-oasis, run `pnpm -r build` over there to
      // refresh dist, or temporarily comment these out.
      "@x-oasis/async-call-rpc": [
        "../../../../../red/x-oasis/packages/async/async-call-rpc/dist/src/index.d.ts"
      ],
      "@x-oasis/async-call-rpc-electron": [
        "../../../../../red/x-oasis/packages/async/async-call-rpc-electron/dist/src/index.d.ts"
      ],
      "@x-oasis/async-call-rpc-web": [
        "../../../../../red/x-oasis/packages/async/async-call-rpc-web/dist/src/index.d.ts"
      ],
      "@x-oasis/deferred": ["../../../../../red/x-oasis/packages/promise/deferred/dist/index.d.ts"]
    }
  },
  // Include the design pagelet's renderer surface so tsc resolves and checks
  // it as part of the telegraph build. The same files are also checked by
  // apps/design/tsconfig.json's own pass — running both is intentional and
  // catches cross-app type drift early.
  "include": ["src/**/*", "../design/src/application/browser/**/*"],
  "exclude": ["node_modules", ".vite", "dist"]
}
