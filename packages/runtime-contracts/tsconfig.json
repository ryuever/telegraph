{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"],
    "baseUrl": ".",
    "paths": {
      "@/packages/runtime-contracts/*": ["./src/*"],
      "@/packages/agent-protocol": ["../agent-protocol/src/index.ts"],
      "@/packages/agent-protocol/*": ["../agent-protocol/src/*"],
      "@telegraph/agent-protocol": ["../agent-protocol/src/index.ts"],
      "@telegraph/agent-protocol/*": ["../agent-protocol/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
