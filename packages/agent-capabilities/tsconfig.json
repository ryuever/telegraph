{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/packages/agent-capabilities": ["./src/index.ts"],
      "@/packages/agent-capabilities/*": ["./src/*"],
      "@/packages/agent-protocol": ["../agent-protocol/src/index.ts"],
      "@/packages/agent-protocol/*": ["../agent-protocol/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
