{
  "name": "@telegraph/agent",
  "version": "0.0.0",
  "description": "Telegraph agent runtime — pi-ai-backed streaming agent and harness framework foundation. Browser-safe (renderer + main).",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./providers/*": "./src/providers/*.ts",
    "./backends/*": "./src/backends/*.ts",
    "./harness": "./src/harness/index.ts",
    "./harness/*": "./src/harness/*.ts",
    "./harness/node": "./src/harness/node/index.ts",
    "./extensions/pi-compat": "./src/extensions/pi-compat/index.ts",
    "./extensions/node": "./src/extensions/node/index.ts",
    "./extensions/ExtensionManifest": "./src/extensions/ExtensionManifest.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.72.1",
    "@telegraph/agent-protocol": "workspace:*",
    "@telegraph/orchestrator-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
