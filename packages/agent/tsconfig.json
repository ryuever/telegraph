{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/packages/agent/*": ["./src/*"],
      "@/packages/runtime-contracts": ["../runtime-contracts/src/index.ts"],
      "@/packages/runtime-contracts/*": ["../runtime-contracts/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules"]
}
