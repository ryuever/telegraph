{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/packages/agent/*": ["./src/*"],
      "@/packages/agent-capabilities": ["../agent-capabilities/src/index.ts"],
      "@/packages/agent-capabilities/*": ["../agent-capabilities/src/*"],
      "@/packages/agent-extension-host": ["../agent-extension-host/src/index.ts"],
      "@/packages/agent-extension-host/*": ["../agent-extension-host/src/*"],
      "@/packages/agent-extensions": ["../agent-extensions/src/index.ts"],
      "@/packages/agent-extensions/*": ["../agent-extensions/src/*"],
      "@/packages/agent-protocol": ["../agent-protocol/src/index.ts"],
      "@/packages/agent-protocol/*": ["../agent-protocol/src/*"],
      "@/packages/agent-resources": ["../agent-resources/src/index.ts"],
      "@/packages/agent-resources/*": ["../agent-resources/src/*"],
      "@/packages/computer-use": ["../computer-use/src/index.ts"],
      "@/packages/computer-use/*": ["../computer-use/src/*"],
      "@/packages/computer-use-protocol": ["../computer-use-protocol/src/index.ts"],
      "@/packages/computer-use-protocol/*": ["../computer-use-protocol/src/*"],
      "@/packages/orchestrator-core": ["../orchestrator-core/src/index.ts"],
      "@/packages/orchestrator-core/*": ["../orchestrator-core/src/*"],
      "@/packages/services/log/*": ["../services/src/log/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules"]
}
