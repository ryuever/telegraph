{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/packages/agent-extension-host": ["../agent-extension-host/src/index.ts"],
      "@/packages/agent-extension-host/*": ["../agent-extension-host/src/*"],
      "@/packages/agent-protocol": ["../agent-protocol/src/index.ts"],
      "@/packages/agent-protocol/*": ["../agent-protocol/src/*"],
      "@/packages/agent-resources": ["./src/index.ts"],
      "@/packages/agent-resources/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
