{
  "name": "@telegraph/agent-extensions",
  "version": "0.0.0",
  "description": "Telegraph agent extension loader: discover, import, and activate command-style factory extensions against a TelegraphExtensionHost.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@telegraph/agent-capabilities": "workspace:*",
    "@telegraph/agent-protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^2.1.8"
  }
}
