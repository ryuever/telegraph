{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/packages/services/*": ["src/*"],
      "@/packages/services/main-metrics/*": ["src/main-metrics/src/*"],
      "@/packages/services/pagelet-host/*": ["src/pagelet-host/src/*"],
      "@/packages/services/process/*": ["src/process/src/*"]
    }
  },
  "include": ["src/**/*"]
}
