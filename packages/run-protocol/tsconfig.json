{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"],
    "baseUrl": ".",
    "paths": {
      "@/packages/run-protocol": ["./src/index.ts"],
      "@/packages/run-protocol/*": ["./src/*"],
      "@/packages/agent-protocol": ["../agent-protocol/src/index.ts"],
      "@/packages/agent-protocol/*": ["../agent-protocol/src/*"],
      "@/packages/remote-protocol": ["../remote-protocol/src/index.ts"],
      "@/packages/remote-protocol/*": ["../remote-protocol/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
