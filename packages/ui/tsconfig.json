{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@telegraph/ui/*": ["./src/*"],
      "@telegraph/application/*": ["../../apps/telegraph/src/application/*"],
      "@telegraph/core/*": ["../../apps/telegraph/src/core/*"],
      "@telegraph/services/*": ["../../apps/telegraph/src/services/*"],
      "@telegraph/agent": ["../agent/src/index.ts"],
      "@telegraph/agent/*": ["../agent/src/*"],
      "@telegraph/stores": ["../stores/src/index.ts"],
      "@telegraph/stores/*": ["../stores/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules"]
}
