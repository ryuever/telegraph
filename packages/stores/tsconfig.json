{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/packages/stores/*": ["./src/*"],
      "@/packages/services/log/*": ["../services/src/log/src/*"]
    },
    "composite": false
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
