{
  "name": "telegraph-monorepo",
  "version": "1.0.0",
  "description": "Telegraph workspace root.",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "start": "pnpm --filter @telegraph/main start",
    "cli": "pnpm --filter @telegraph/cli exec telegraph",
    "package": "pnpm --filter telegraph package",
    "make": "pnpm --filter telegraph make",
    "docs:wiki:dev": "vitepress dev",
    "docs:wiki:build": "vitepress build",
    "docs:wiki:preview": "vitepress preview",
    "cleanup:dev": "node scripts/cleanup-dev-processes.mjs",
    "cleanup:dev:dry-run": "node scripts/cleanup-dev-processes.mjs --dry-run",
    "clean:build": "pnpm -r exec rm -rf out dist .vite",
    "clean": "pnpm run clean:build && pnpm run clean:modules",
    "clean:modules": "rm -rf node_modules && pnpm -r exec rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-tailwindcss": "^3.17.5",
    "happy-dom": "^20.9.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.18.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
