{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/extensions/telegraph-subagents/*": ["./*"],
      "@/packages/agent/*": ["../../packages/agent/src/*"],
      "@/packages/agent-protocol": ["../../packages/agent-protocol/src/index.ts"],
      "@/packages/agent-protocol/*": ["../../packages/agent-protocol/src/*"],
      "@/packages/orchestrator-core": ["../../packages/orchestrator-core/src/index.ts"],
      "@/packages/orchestrator-core/*": ["../../packages/orchestrator-core/src/*"]
    }
  },
  "include": ["src/**/*", "telegraph.extension.json"]
}
