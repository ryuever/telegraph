{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    "strictNullChecks": true,
    "paths": {
      "@app/*": ["./app/*"],
      "@common/*": ["./app/common/*"],
      "@ui/*": ["./ui/*"]
    }
  },
  "include": [
    "app",
    "ui",
    "*.{ts,json,js}",
    "vite.main.config.ts",
    "vite.preload.config.ts",
    "vite.fork.config.ts",
    "forge.config.ts"
  ],
  "exclude": [
    "node_modules",
    "out"
  ]
}
